# Copie para .env local ou configure na Vercel (Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# Opcional: grava pedidos no painel (Dashboard > Pedidos). Project Settings > API > service_role
# Nunca exponha no frontend. Também é obrigatória para o painel do admin (/admin).
SUPABASE_SERVICE_ROLE_KEY=

# Painel do admin (dono do SaaS): e-mails autorizados a acessar /admin.
# Separe por vírgula para mais de um. Nunca use NEXT_PUBLIC_ aqui.
ADMIN_EMAILS=felipeari2007@gmail.com

# Mercado Pago — SUA conta. São DOIS tokens porque cada aplicação do MP tem um
# produto só: um app de Checkout Pro responde UNAUTHORIZED em /preapproval.
# Só servidor; use TEST-... para testar.
# App "Checkout Pro" -> recarga de créditos da IA (/dashboard/creditos)
MP_ACCESS_TOKEN=
# App "Assinaturas" -> mensalidade automática do SaaS (/dashboard/planos)
MP_SUBSCRIPTION_ACCESS_TOKEN=
